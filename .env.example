# Database
POSTGRES_USER=orion_user # Database administrative user
POSTGRES_PASSWORD=change_me_strong_password # Database administrative password
DATABASE_URL=postgresql://orion_user:change_me_strong_password@postgres:5432/orion # Full Prisma-compatible database connection string

# RabbitMQ
RABBITMQ_USER=orion_rmq # RabbitMQ administrative user
RABBITMQ_PASSWORD=change_me_strong_password # RabbitMQ administrative password
RABBITMQ_URL=amqp://orion_rmq:change_me_strong_password@rabbitmq:5672 # Full RabbitMQ connection string

# Auth
JWT_SECRET=generate_a_256bit_random_string_here # Secret key for signing JWT tokens

# LLM
GEMINI_API_KEY=your_google_ai_studio_key_here # Google AI Studio API key for Gemini 1.5 Flash

# Monitoring
GRAFANA_PASSWORD=change_me # Admin password for Grafana dashboard

# GitHub (for image tags in CI)
GITHUB_USERNAME=your_github_username # Your GitHub username for GHCR tagging
IMAGE_TAG=latest # Docker image tag to use
